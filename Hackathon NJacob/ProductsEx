import pandas as pd
import numpy as np
from datetime import datetime, timedelta

# Number of products
n = 20

# Column structure
columns = [
    "Product",
    "Code",
    "Quality",
    "ExpDate"
]

data = []

for i in range(n):
    # Product name
    product_name = f"Product {i+1}"
    
    # Random product code (e.g., 6-digit)
    code = np.random.randint(100000, 999999)

    # Random quality (Correct, Tres Bon, Superieur)
    quality = np.random.choice(["Correct", "Tres Bon", "Superieur"])
    
    # Random expiration date (between today and +365 days)
    days_to_add = np.random.randint(1, 366)
    exp_date = datetime.today() + timedelta(days=int(days_to_add))
    exp_date = exp_date.strftime("%Y-%m-%d")
    
    row = [product_name, code, quality, exp_date]
    data.append(row)

# Create DataFrame
df_products = pd.DataFrame(data, columns=columns)

# flag products near expiration (< 30 days)
df_products["DaysBeforeExpiry"] = (
    pd.to_datetime(df_products["ExpDate"]) - datetime.today()
).dt.days

df_products["ExpiringSoon?"] = df_products["DaysBeforeExpiry"] <= 30

# Save file
df_products.to_csv("products_generated.csv", index=False)

# Filter products near expiration
df_contact = df_products[df_products["ExpiringSoon?"] == True]
df_contact.to_csv("Expiring products.csv", index=False)

print("File generated:")
print("- products_generated.csv")